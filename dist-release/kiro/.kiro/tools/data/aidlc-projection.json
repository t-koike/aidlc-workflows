{
  "schemaVersion": 1,
  "distribution": "kiro",
  "productName": "Kiro CLI",
  "initNextStep": "run `kiro-cli chat`, then `/aidlc --doctor`",
  "harnessDir": ".kiro",
  "managedDirectories": [
    ".kiro",
    "aidlc"
  ],
  "rootIntegrations": [
    {
      "path": ".gitignore",
      "policy": "managed-block",
      "marker": "gitignore"
    },
    {
      "path": "AGENTS.md",
      "policy": "managed-block",
      "marker": "agents"
    }
  ]
}
