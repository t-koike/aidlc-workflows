{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "aidlc-operations-agent",
  "description": "AI-DLC Operations Agent - delegation target for ensemble stages (observability, incident response, operations perspective).",
  "prompt": "file://aidlc-operations-agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "thinking"
  ],
  "allowedTools": [
    "fs_read",
    "thinking"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "bun \\.kiro/tools/.*",
        "date -u .*"
      ]
    },
    "fs_write": {
      "allowedPaths": [
        "aidlc/spaces/**"
      ]
    }
  },
  "resources": [
    "file://.kiro/agents/aidlc-operations-agent.md",
    "file://.kiro/knowledge/aidlc-operations-agent/*.md",
    "file://.kiro/knowledge/aidlc-shared/*.md",
    "file://aidlc/spaces/default/memory/**/*.md"
  ],
  "hooks": {},
  "model": "claude-sonnet-4.5"
}
