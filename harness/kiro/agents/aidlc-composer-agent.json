{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "aidlc-composer-agent",
  "description": "AI-DLC Composer Agent - delegation target for composing a workflow plan (front, report, or in-flight). Proposes the EXECUTE/SKIP grid; after human approval writes the composed scope data.",
  "prompt": "file://aidlc-composer-agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "thinking"
  ],
  "allowedTools": [
    "fs_read",
    "thinking"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "{{INVOKE}} .*",
        "date -u .*"
      ]
    },
    "fs_write": {
      "allowedPaths": [
        ".kiro/scopes/**",
        ".kiro/tools/data/scope-grid.json"
      ]
    }
  },
  "resources": [
    "file://.kiro/agents/aidlc-composer-agent.md",
    "file://.kiro/scopes/*.md",
    "file://.kiro/knowledge/aidlc-shared/*.md",
    "file://aidlc/spaces/default/memory/**/*.md"
  ],
  "hooks": {}
}
