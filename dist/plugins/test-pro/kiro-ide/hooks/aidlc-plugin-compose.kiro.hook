{
  "version": "1.0.0",
  "enabled": true,
  "name": "aidlc-test-pro-compose",
  "description": "Composes the test-pro AIDLC plugin on first interaction.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "sh -c 'AIDLC=$(command -v aidlc 2>/dev/null || true); [ -n \"$AIDLC\" ] && { AIDLC_HARNESS_DIR=.kiro \"$AIDLC\" plugin sync; exit $?; }; BUN=$(command -v bun 2>/dev/null || true); [ -z \"$BUN\" ] && [ -x \"$HOME/.bun/bin/bun\" ] && BUN=\"$HOME/.bun/bin/bun\"; [ -z \"$BUN\" ] && { echo \"aidlc plugin compose: aidlc and bun not found, skipping\" >&2; exit 0; }; PROJECT_ROOT=\"${CLAUDE_PROJECT_DIR:-${AIDLC_PROJECT_DIR:-$PWD}}\"; PLUGIN_TOOL=\"$PROJECT_ROOT/.kiro/tools/aidlc-plugin.ts\"; [ -f \"$PLUGIN_TOOL\" ] && { AIDLC_HARNESS_DIR=.kiro \"$BUN\" \"$PLUGIN_TOOL\" sync; exit $?; }; AIDLC_HARNESS_DIR=.kiro \"$BUN\" \"${PLUGIN_ROOT}/hooks/compose.ts\"'"
  }
}
