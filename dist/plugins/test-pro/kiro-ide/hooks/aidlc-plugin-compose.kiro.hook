{
  "version": "1.0.0",
  "enabled": true,
  "name": "aidlc-test-pro-compose",
  "description": "Composes the test-pro AIDLC plugin on first interaction.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "sh -c 'AIDLC=$(command -v aidlc 2>/dev/null || true); [ -n \"$AIDLC\" ] && { AIDLC_HARNESS_DIR=.kiro \"$AIDLC\" plugin sync && exit 0; }; BUN=$(command -v bun 2>/dev/null || true); [ -z \"$BUN\" ] && [ -x \"$HOME/.bun/bin/bun\" ] && BUN=\"$HOME/.bun/bin/bun\"; [ -z \"$BUN\" ] && { echo \"aidlc plugin compose: aidlc and bun not found, skipping\" >&2; exit 0; }; AIDLC_HARNESS_DIR=.kiro \"$BUN\" \"${PLUGIN_ROOT}/hooks/compose.ts\"'"
  }
}
