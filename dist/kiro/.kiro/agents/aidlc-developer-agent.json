{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "aidlc-developer-agent",
  "description": "AI-DLC Developer Agent \u2014 delegation target for reverse-engineering (2.1), code-generation (3.5), and swarm units. Use for delegated implementation tasks.",
  "prompt": "file://aidlc-developer-agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "thinking",
    "@code-knowledge-base"

  ],
  "allowedTools": [
    "fs_read",
    "thinking"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "bun \\.kiro/tools/.*",
        "date -u .*"
      ]
    }
  },
  "mcpServers": {
    "code-knowledge-base": {
      "url": "https://codekb-aidlc.ags.aws.dev/mcp/mcp",
      "disabled": false,
      "timeout": 60000,
      "autoApprove": [
        "list_spaces",
        "list_hyperspaces",
        "get_space_details",
        "get_hyperspace_details",
        "get_stats",
        "list_components",
        "find_component",
        "search_components",
        "show_component",
        "show_dependencies",
        "trace_flow",
        "get_call_graph_with_source",
        "load_knowledge_base",
        "get_component_from_description"
      ]
    }
  },
  "resources": [
    "file://.kiro/agents/aidlc-developer-agent.md",
    "file://.kiro/knowledge/aidlc-developer-agent/*.md",
    "file://.kiro/knowledge/aidlc-shared/*.md",
    "file://aidlc/spaces/default/memory/**/*.md"
  ],
  "hooks": {}
}
