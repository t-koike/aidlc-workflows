{
  "$schema": "https://raw.githubusercontent.com/aws/amazon-q-developer-cli/refs/heads/main/schemas/agent-v1.json",
  "name": "aidlc-pipeline-deploy-agent",
  "description": "AI-DLC Pipeline & Deploy Agent - delegation target for ensemble stages (CI/CD, deployment pipeline perspective).",
  "prompt": "file://aidlc-pipeline-deploy-agent.md",
  "tools": [
    "fs_read",
    "fs_write",
    "execute_bash",
    "thinking"
  ],
  "allowedTools": [
    "fs_read",
    "thinking"
  ],
  "toolsSettings": {
    "execute_bash": {
      "allowedCommands": [
        "aidlc .*",
        "date -u .*"
      ]
    },
    "fs_write": {
      "allowedPaths": [
        "aidlc/spaces/**"
      ]
    }
  },
  "resources": [
    "file://.kiro/agents/aidlc-pipeline-deploy-agent.md",
    "file://.kiro/knowledge/aidlc-pipeline-deploy-agent/*.md",
    "file://.kiro/knowledge/aidlc-shared/*.md",
    "file://aidlc/spaces/default/memory/**/*.md"
  ],
  "hooks": {},
  "model": "claude-sonnet-4.5"
}
