{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex session-start"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex mint"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex reviewer-scope"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex audit-and-sensors"
          }
        ],
        "matcher": "apply_patch"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex state-sync"
          }
        ],
        "matcher": "update_plan"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex runtime-compile"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex validate-state"
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex post-compact"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex log-subagent"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun .codex/tools/aidlc.ts adapter codex stop"
          }
        ]
      }
    ]
  }
}
