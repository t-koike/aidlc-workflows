{
  "title": "Intent State",
  "description": "Tracks progress through the workflow. One file per intent at state/state.json.",
  "type": "object",
  "required": ["intent", "created", "updated", "path", "stages"],
  "properties": {
    "intent": {
      "type": "string",
      "description": "Intent name/slug"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "When the intent was created"
    },
    "updated": {
      "type": "string",
      "format": "date-time",
      "description": "Last state update timestamp"
    },
    "path": {
      "type": "string",
      "description": "Which workflow path was chosen (e.g. A, B, C, D, or custom)"
    },
    "stages": {
      "type": "array",
      "description": "Progress for each stage in the composed workflow",
      "items": {
        "type": "object",
        "required": ["stage", "status", "owner"],
        "properties": {
          "stage": {
            "type": "string",
            "description": "Stage name"
          },
          "unit": {
            "type": "string",
            "description": "Unit name for construction-phase stages. Absent for inception stages."
          },
          "scope": {
            "type": "string",
            "description": "Scope name for multi-instance stages. Absent for single-instance stages."
          },
          "status": {
            "type": "string",
            "enum": [
              "pending",
              "plan-and-clarify",
              "clarification-asked",
              "clarification-provided",
              "further-clarification",
              "artifact-generated",
              "review-needed",
              "reviewed",
              "refined",
              "presented",
              "changes-requested",
              "complete"
            ],
            "description": "Current status — set by the actor who performed the action"
          },
          "owner": {
            "type": "string",
            "description": "Persona responsible for this stage"
          },
          "contributors": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Personas assigned as contributors"
          },
          "reviews": {
            "type": "array",
            "description": "Review status for each assigned contributor",
            "items": {
              "type": "object",
              "required": ["persona", "reviewed"],
              "properties": {
                "persona": {
                  "type": "string",
                  "description": "Contributor persona name"
                },
                "reviewed": {
                  "type": "boolean",
                  "description": "Whether this persona has completed their review"
                }
              }
            }
          },
          "outputs": {
            "type": "array",
            "description": "List of output artifacts produced",
            "items": {
              "type": "object",
              "required": ["name", "locationRelativeToIntentRoot"],
              "properties": {
                "name": {
                  "type": "string",
                  "description": "Filename only (e.g. 'intent.md', 'requirements.md', 'state.json')"
                },
                "locationRelativeToIntentRoot": {
                  "type": "string",
                  "description": "DIRECTORY path relative to intent root where the file lives. Must end with '/'. Examples: '/' for intent root, '/state/' for state directory, '/stages/requirements-analysis/' for a domain stage directory. The full file path is: <intent-dir> + locationRelativeToIntentRoot + name"
                }
              }
            }
          }
        }
      }
    }
  }
}
